<UserControl x:Class="Sg.App.Views.Admin.TimeSyncView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Margin="16">
        <TextBlock Text="Time Sync" FontSize="20" FontWeight="Bold" Margin="0,0,0,12"/>
        <TextBlock Text="{Binding NtpPeer,         StringFormat='Peer: {0}'}"             Margin="0,2"/>
        <TextBlock Text="{Binding Status,          StringFormat='Status: {0}'}"           Margin="0,2"/>
        <TextBlock Text="{Binding CurrentOffsetMs, StringFormat='Offset: {0:F2} ms'}"     Margin="0,2"/>
        <TextBlock Text="{Binding CurrentJitterMs, StringFormat='Jitter: {0:F2} ms'}"     Margin="0,2"/>
        <TextBlock Text="{Binding LastSync,        StringFormat='Last sync: {0:yyyy-MM-dd HH:mm:ss} UTC'}" Margin="0,2"/>
        <Button   Content="Refresh"               Command="{Binding RefreshCommand}"      Margin="0,12,0,0" HorizontalAlignment="Left" Padding="12,4"/>
    </StackPanel>
</UserControl>
