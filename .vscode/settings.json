{
  "files.associations": {
    "*.czml": "json",
    "*.sc": "plaintext",
    "*.vdf": "plaintext"
  },
  "files.exclude": {
    "**/bin": true,
    "**/obj": true,
    "**/node_modules": true,
    "**/.angular": true
  },
  "search.exclude": {
    "**/bin": true,
    "**/obj": true,
    "**/node_modules": true,
    "**/package-lock.json": true,
    "docs/ewtss/legacy": false
  },
  "editor.rulers": [120],
  "editor.formatOnSave": false,
  "[csharp]": {
    "editor.formatOnSave": true,
    "editor.tabSize": 4
  },
  "[markdown]": {
    "editor.wordWrap": "on",
    "editor.tabSize": 2,
    "editor.formatOnSave": false
  },
  "markdown.extension.toc.levels": "2..6",
  "cSpell.words": [
    "AGI",
    "aiokafka",
    "asyncpg",
    "AreaTarget",
    "CesiumJS",
    "CMake",
    "CZML",
    "DTED",
    "drs",
    "ewtss",
    "FastAPI",
    "GNSS",
    "Hypertable",
    "JHF",
    "JLB",
    "JMB",
    "JHB",
    "JSVUSHF",
    "Kafka",
    "Mvp",
    "MVVM",
    "NMEA",
    "OpenAPI",
    "PADS",
    "PostgreSQL",
    "RDFS",
    "RLOS",
    "Sg",
    "SJRR",
    "SDFC",
    "STK",
    "SRX",
    "MRX",
    "Stk",
    "TimescaleDB",
    "Timescale",
    "WPF",
    "asyncio",
    "ctypes",
    "geodetic",
    "ipynb",
    "msi",
    "openpyxl",
    "uvicorn",
    "WindowsFormsHost"
  ],
  "cmake.sourceDirectory": "${workspaceFolder}/drs-bridge/parsers/reference"
}
