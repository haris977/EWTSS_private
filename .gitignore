# Claude Code config — track the team-shared settings + agent guide,
# ignore personal overrides and all runtime/session artefacts.
.claude/*
!.claude/settings.json
.claude/settings.local.json

# IQ data / large binary test data
IQ_data/
*.iq
*.bin

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.venv/
venv/
env/

# Environment / secrets
.env
*.env.local

# Vendored packages (large, offline-install dirs) — keep docs, ignore binaries
packages/**/*
!packages/**/
!packages/**/*.md
!packages/**/README*
!packages/THIRD-PARTY-LICENCES.md

# Node / Angular
node_modules/
dist/
.angular/

# IDE — track team-wide .vscode/ files explicitly; ignore everything else
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
.idea/
*.swp

# Archives (already have extracted versions)
*.zip
*.tar.gz

# OS
Thumbs.db
.DS_Store

# Logs
*.log

# packageschanged796
ewtss-backend/packageschanged796/

# .NET build artifacts
bin/
obj/
*.user
*.suo
.vs/
