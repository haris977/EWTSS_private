<UserControl x:Class="Sg.Mvp4.App.Views.Entities.AreaTargetPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel>
        <TextBlock DockPanel.Dock="Top" Margin="8" FontWeight="Bold"
                   Text="{Binding EntityName, StringFormat='Area Target: {0}'}" />

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="8">
            <Button Content="Edit on Map" Click="EditOnMap_Click" Width="100" Margin="0,0,12,0" />
            <Button Content="Reset" Command="{Binding ResetCommand}" Width="70" Margin="4,0" />
            <Button Content="Apply" Command="{Binding ApplyCommand}" Width="70" />
        </StackPanel>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="8">
                <TextBlock Text="Outline Color (#RRGGBB)" />
                <TextBox Text="{Binding OutlineColorHex, UpdateSourceTrigger=PropertyChanged}" />

                <CheckBox Content="Fill enabled" IsChecked="{Binding FillEnabled}" Margin="0,8" />

                <TextBlock Text="Fill Color (#RRGGBB)" Margin="0,4,0,0" />
                <TextBox Text="{Binding FillColorHex, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Text="Vertices" FontWeight="Bold" Margin="0,8,0,4" />
                <DataGrid ItemsSource="{Binding Vertices}" AutoGenerateColumns="False"
                          CanUserAddRows="False" MinHeight="120" MaxHeight="240">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Lat °" Binding="{Binding LatitudeDeg}"  Width="120" />
                        <DataGridTextColumn Header="Lon °" Binding="{Binding LongitudeDeg}" Width="120" />
                    </DataGrid.Columns>
                </DataGrid>
                <Button Content="+ Add vertex" Command="{Binding AddVertexCommand}" Margin="0,4" />
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
